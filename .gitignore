# Composer vendor committed directly (no SSH/terminal on server)
# /vendor/

# SMTP credentials — fill in api/config/email_config.php on the server
api/config/email_config.php

# Diagnostic / test scripts — never commit these
test-mail.php

# User uploads — images uploaded by shops/admins at runtime
# Directories are preserved via .gitkeep files for fresh clones
uploads/products/*
!uploads/products/.gitkeep
uploads/shops/*
!uploads/shops/.gitkeep

# Claude Code local settings
.claude/settings.local.json

# Archive files
*.zip
*.tar.gz

# OS files
.DS_Store
Thumbs.db
